{
	"name": "bun-react-template",
	"version": "0.1.0",
	"scripts": {
		"dev": "bun --hot server.ts",
		"start": "NODE_ENV=production bun server.ts",
		"build": "rm -rf dist; bun build --production --target=bun --outdir=dist server.ts",
		"run-dist": "bun --cwd=dist server.js",
		"docker-build": "docker build -t bun-react-template .",
		"run-docker": "docker run --rm -it --net=host bun-react-template",
		"upgrade": "bun update --latest",
		"check": "bun run --sequential --no-exit-on-error check:clean check:deno check:oxlint check:biome check:export lint",
		"lint": "tsc --noEmit",
		"all": "bun run --sequential --no-exit-on-error upgrade check",
		"check:clean": "rm -rf dist out build",
		"check:deno": "deno fmt --use-tabs --quiet",
		"check:oxlint": "oxlint --fix-dangerously --quiet",
		"check:biome": "timeout 3s biome check --write --unsafe .",
		"check:export": "ts-unused-exports tsconfig.json"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"@tanstack/react-query": "^5.97.0",
		"hono": "^4.12.12",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"wouter": "^3.9.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"typescript": "^6.0.2"
	}
}
